generator client {
  provider        = "prisma-client-js"
  output          = "../node_modules/prisma-wasm-edge"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth ───────────────────────────────────────────────────────────────────

enum Rolle {
  ADMIN
  KUNDE
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwort           String?
  rolle              Rolle     @default(KUNDE)
  aktiv              Boolean   @default(true)
  mustChangePassword Boolean   @default(false)
  passwortGeaendert  Boolean   @default(false)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  zugriffe KundenprofilZugriff[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model KundenprofilZugriff {
  id             String   @id @default(cuid())
  userId         String
  kundenprofilId String
  kundenRolle    String   @default("Inhaber")
  createdAt      DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  kundenprofil Kundenprofil @relation(fields: [kundenprofilId], references: [id], onDelete: Cascade)

  @@unique([userId, kundenprofilId])
}

// ─── Formular-Config ────────────────────────────────────────────────────────

model FormularConfig {
  id         String   @id @default(cuid())
  slug       String   @unique
  name       String
  introText  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ─── Kundenprofil ───────────────────────────────────────────────────────────

model Kundenprofil {
  id        String   @id @default(cuid())
  kundenNr  Int      @unique @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Kontaktdaten
  unternehmensname     String?
  ansprechpartner      String?
  geschaeftsadresse    String?
  emailAnsprechpartner String?
  branche              String?
  telefonnummer        String?
  webseite             String?
  emailDirekt          String?
  socialMediaKanaele   String?
  linkInstagram        String?
  linkFacebook         String?
  linkTikTok           String?
  linkYouTube          String?

  // Freigabe
  freigabeVerantwortlicher       String?
  emailFreigabeVerantwortlicher  String?
  freigabeVerantwortlicher2      String?
  emailFreigabeVerantwortlicher2 String?
  cloudLink                     String?
  kundeDriveLink                String?
  zusatzlinks                   String?
  contentStrategieMailGesendet  DateTime?

  // Vertrag & Status
  vertragsstart                     DateTime?
  statusKunde                       String?
  kundenKategorie                   String?
  letzterKontakt                    DateTime?
  kundenzufriedenheit               String?
  vertraglicheFestgelegtePostAnzahl Float?
  limitReel                         Int?
  limitStory                        Int?
  limitBild                         Int?
  limitKarussell                    Int?
  limitGesperrtAb                   DateTime?
  archiv                            String?
  kundenfeedback                    String?
  notizenIntern                     String?

  // Content-Planung
  contentIdeen    String?
  contentPlan     String[]
  postingKalender String?

  // Rechtliches
  mitarbeiterImBildRechtlichGeklaert String?
  mitarbeiterImBildRechtlichGeregelt String?
  mitarbeiterNichtZeigen             String?
  welcheMitarbeiterNichtZeigen       String?
  sensibleBereiche                   String?
  welcheBereicheNichtZeigen          String?

  // Drehtag
  modul                  String?
  drehtageAnWelchenTagen String[]
  drehtageUhrzeiten      String?
  ansprechpartnerDrehtag String?
  einschraenkungenVorOrt String?
  selbstAuftreten        String?
  wunschdatum            DateTime?

  // Drehtag-Planung
  drehtag                          DateTime?
  drehtageAdresse                  String?
  drehtageStatus                   String?
  drehtageErinnerungTagGesendet    DateTime?
  drehtageErinnerungStundeGesendet DateTime?

  // Marke & Zielgruppe
  kurzbeschreibung         String?
  kernwerte                String?
  alleinstellungsmerkmale  String?
  haeufigsteProbleme       String?
  haeufigsteEinwaende      String?
  zielgruppeOnline         String?
  wasKundenLieben          String?
  zielgruppe               String?
  hauptziel                String?

  // Produkte & Events
  heroProdukte             String?
  wiederkehrendeProdukte   String?
  eventsNaechsteMonate     String?

  // Sonstiges
  besonderheitenPlanung        String?
  herausforderungen            String?
  vorbereiteteFragenBesprechen String?

  // Content-Strategie-Fragebogen (zusätzlich)
  zusammenarbeitZiel             String?
  hervorgehobeneDienstleistungen String?
  zielgruppeOnlineKanaele        String[]
  irrtuemerBranche               String?
  geruechteVorurteile            String?
  haeufigsteKundenfragen         String?
  typischeFehlerKunden           String?
  einSacheZielgruppe             String?
  bestPracticesTipps             String?
  contentThemen                  String[]
  contentThemenZusatz            String?
  contentStil                    String[]

  // Start-Seite Konfiguration
  startVideoUrl String?
  startFaqItems String[]

  // DSGVO
  dsgvoLoeschdatum          DateTime?
  dsgvoStatus               String?    // "aktiv" | "eingeschraenkt" | "loeschung_beantragt"
  keinMarketing             Boolean   @default(false)
  verarbeitungEinschraenken Boolean   @default(false)

  // Sichtbarkeit für Kunden
  kpisFreigegeben Boolean @default(false)

  // Automatische E-Mails
  feedbackEmailGesendetAm DateTime?

  // Relations
  zugriffe        KundenprofilZugriff[]
  contentIdeen_   ContentIdea[]
  kalender        KalenderEintrag[]
  archivEintraege ArchivEintrag[]
  kpis            KPI[]
  kundendaten     Kundendaten[]
  socialAccounts  SocialAccount[]
}

// ─── Social Accounts ─────────────────────────────────────────────────────────

model SocialAccount {
  id             String    @id @default(cuid())
  kundenprofilId String
  plattform      String
  accountId      String
  accountName    String?
  accountHandle  String?
  accessToken    String    @db.Text
  pageId         String?
  pageToken      String?   @db.Text
  tokenExpiry    DateTime?
  syncedAt       DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  kundenprofil Kundenprofil @relation(fields: [kundenprofilId], references: [id], onDelete: Cascade)

  @@unique([kundenprofilId, plattform, accountId])
}

// ─── Audit-Log ──────────────────────────────────────────────────────────────

model AuditLog {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  aktion        String   // "exportiert" | "anonymisiert" | "geloescht" | "geaendert" | "zugegriffen"
  entitaet      String   // "Kundenprofil"
  entitaetId    String
  benutzerEmail String?
  details       String?
}

// ─── Globale FAQ ─────────────────────────────────────────────────────────────

model GlobalFaqItem {
  id          String   @id @default(cuid())
  frage       String
  reihenfolge Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Fehlerprotokoll ────────────────────────────────────────────────────────

model FehlerLog {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  fehlerCode  String?
  nachricht   String
  kontext     String?
  url         String?
  benutzerTyp String?  // "Admin" | "Kunde" | "System"
}

// ─── E-Mail-Vorlagen ────────────────────────────────────────────────────────

model EmailVorlage {
  id           String   @id @default(cuid())
  name         String
  beschreibung String?
  betreff      String
  html         String   @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ─── Content-Ideen ──────────────────────────────────────────────────────────

model ContentIdea {
  id             String   @id @default(cuid())
  kundenprofilId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  titel                    String?
  beschreibung             String?
  plattform                String[]
  contentTyp               String?
  eingereichtVon           String?
  einreichungsdatum        DateTime?
  prioritaet               String?
  status                   String?
  notizen                  String?
  gewuenschtesPostingDatum DateTime?
  captionText              String?
  dateizugriff             String?

  kundenprofil Kundenprofil    @relation(fields: [kundenprofilId], references: [id], onDelete: Cascade)
  kommentare   IdeenKommentar[]
}

model IdeenKommentar {
  id            String      @id @default(cuid())
  contentIdeaId String
  text          String
  autorTyp      String      // "Kunde" | "Agentur"
  autorName     String?
  createdAt     DateTime    @default(now())

  contentIdea ContentIdea @relation(fields: [contentIdeaId], references: [id], onDelete: Cascade)
}

// ─── Kalender ───────────────────────────────────────────────────────────────

model KalenderEintrag {
  id             String   @id @default(cuid())
  kundenprofilId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  titel             String?
  beschreibung      String?
  plattform         String[]
  contentTyp        String?
  eingereichtVon    String?
  einreichungsdatum DateTime?
  prioritaet        String?
  notizen           String?
  captionText       String?
  dateizugriff      String?
  geplantAm         DateTime?
  gepostet          Boolean  @default(false)
  gepostetAm        DateTime?
  archiviert        Boolean  @default(false)

  // Freigabe
  freigabeStatus    String   @default("Ausstehend") // Ausstehend | Freigegeben | Abgelehnt | Überarbeitung
  freigabeKommentar String?
  freigegebenAm     DateTime?

  kundenprofil Kundenprofil @relation(fields: [kundenprofilId], references: [id], onDelete: Cascade)
}

// ─── Archiv ─────────────────────────────────────────────────────────────────

model ArchivEintrag {
  id             String   @id @default(cuid())
  kundenprofilId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  titel             String?
  beschreibung      String?
  plattform         String[]
  contentTyp        String?
  eingereichtVon    String?
  einreichungsdatum DateTime?
  prioritaet        String?
  notizen           String?
  captionText       String?
  dateizugriff      String?
  archivdatum       DateTime?
  gepostetAm        DateTime?

  kundenprofil Kundenprofil    @relation(fields: [kundenprofilId], references: [id], onDelete: Cascade)
  kommentare   ArchivKommentar[]
}

model ArchivKommentar {
  id              String        @id @default(cuid())
  archivEintragId String
  text            String
  autorTyp        String        // "Kunde" | "Agentur"
  autorName       String?
  createdAt       DateTime      @default(now())

  archivEintrag ArchivEintrag @relation(fields: [archivEintragId], references: [id], onDelete: Cascade)
}

// ─── KPIs / Monitoring ──────────────────────────────────────────────────────

model KPI {
  id             String   @id @default(cuid())
  kpiNr          Int      @unique @default(autoincrement())
  kundenprofilId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  monatJahr String?
  plattform String?

  reichweite     Int?
  impressionen   Int?
  follower       Int?
  engagementRate Float?
  kommentare     Int?
  likes          Int?
  shares         Int?
  saves          Int?
  klicks         Int?

  reichweiteVormonat     Int?
  impressionenVormonat   Int?
  followerVormonat       Int?
  engagementRateVormonat Float?
  kommentareVormonat     Int?
  likesVormonat          Int?
  sharesVormonat         Int?
  savesVormonat          Int?
  klicksVormonat         Int?

  reichweiteVor2M     Int?
  impressionenVor2M   Int?
  followerVor2M       Int?
  engagementRateVor2M Float?
  kommentareVor2M     Int?
  likesVor2M          Int?
  sharesVor2M         Int?
  savesVor2M          Int?
  klicksVor2M         Int?

  analyseKommentar      String?
  handlungsempfehlungen String?
  statusMonitoring      String?
  reportGesendet        Boolean @default(false)
  kpiTyp                String?
  anomalieErkennung     String?

  kundenprofil Kundenprofil @relation(fields: [kundenprofilId], references: [id], onDelete: Cascade)
  dateien      KPIDatei[]
}

model KPIDatei {
  id        String   @id @default(cuid())
  kpiId     String
  name      String
  url       String
  typ       String   // "video", "pdf", "presentation", "other"
  groesse   Int?
  createdAt DateTime @default(now())

  kpi KPI @relation(fields: [kpiId], references: [id], onDelete: Cascade)
}

// ─── Kundendaten ────────────────────────────────────────────────────────────

model Kundendaten {
  id             String   @id @default(cuid())
  kundenprofilId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  beschreibung    String?
  inhalt          String?
  veraltet        Boolean  @default(false)
  datum           DateTime?
  tags            String[]
  hinzugefuegtVon String?
  anhaenge        String[]

  kundenprofil Kundenprofil @relation(fields: [kundenprofilId], references: [id], onDelete: Cascade)
}
